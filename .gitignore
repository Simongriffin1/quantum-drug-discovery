# Byte-compiled / cache
__pycache__/
*.py[cod]
*$py.class
.mypy_cache/
.ruff_cache/
.pytest_cache/
*.egg-info/
.eggs/
dist/
build/
.coverage
htmlcov/

# Virtualenvs
.venv/
venv/
core/.venv/
backend/.venv/

# Node
frontend/node_modules/
frontend/.next/
frontend/out/
npm-debug.log*

# IDE / OS
.DS_Store
.idea/
.vscode/
*.swp

# Env / secrets
.env
.env.*
!.env.example
credentials.json
*.pem

# Data / artifacts (never commit real physics trajectories casually)
data/
!benchmarks/peptide_affinity/data/
benchmarks/peptide_affinity/data/raw/
benchmarks/peptide_affinity/data/prepared/
benchmarks/peptide_affinity/data/full_pdbs/
benchmarks/peptide_affinity/data/*.db
*.dcd
*.xtc
mlruns/
.mlflow/
# Poetry lock optional at scaffold; prefer committing locks later
# poetry.lock

# Ignore large full PDBs / local MLflow DBs in structures (interface PDBs are tracked)
benchmarks/fixtures/structures/*_full.pdb
benchmarks/fixtures/structures/oracle_validity_mlflow.db
benchmarks/fixtures/structures/mlruns/
benchmarks/fixtures/structures/synthetic_mini/
benchmarks/peptide_affinity/data/pepbench_rcsb_map.json
benchmarks/peptide_affinity/data/rcsb_probe.json

# SKEMPI: keep converted TSV; ignore raw/structures
!benchmarks/skempi/data/
benchmarks/skempi/data/structures/
benchmarks/skempi/data/*_raw.csv
benchmarks/skempi/data/skempi_mutant_pdbs/

# Authorization + fold degradation artifacts (keep JSON; ignore fold caches)
!benchmarks/authorization/
benchmarks/skempi/data/predicted_folds/cache/
