{
  "$defs": {
    "Provenance": {
      "additionalProperties": false,
      "description": "Traceability metadata attached to every stored result.\n\ngit_sha + data_version + tool_versions make every number auditable.\nMissing fields are allowed only for in-memory synthetic plumbing tests.",
      "properties": {
        "git_sha": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Git Sha"
        },
        "data_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Data Version"
        },
        "tool_versions": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Tool Versions",
          "type": "object"
        },
        "config_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Config Hash"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        }
      },
      "title": "Provenance",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Folded peptide\u2013target complex from a StructurePredictor.\n\nCoordinates are represented as PDB text or a path reference \u2014 never\nfabricated atomic coordinates in callers. Missing deps must raise, not\ninvent structures.",
  "properties": {
    "complex_id": {
      "format": "uuid",
      "title": "Complex Id",
      "type": "string"
    },
    "candidate_id": {
      "format": "uuid",
      "title": "Candidate Id",
      "type": "string"
    },
    "target_id": {
      "minLength": 1,
      "title": "Target Id",
      "type": "string"
    },
    "sequence": {
      "title": "Sequence",
      "type": "string"
    },
    "pdb_path": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Pdb Path"
    },
    "pdb_text": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Pdb Text"
    },
    "confidence": {
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Confidence",
      "type": "number"
    },
    "affinity_estimate": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Affinity Estimate"
    },
    "fold_method": {
      "minLength": 1,
      "title": "Fold Method",
      "type": "string"
    },
    "cache_key": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Cache Key"
    },
    "provenance": {
      "$ref": "#/$defs/Provenance"
    }
  },
  "required": [
    "candidate_id",
    "target_id",
    "sequence",
    "confidence",
    "fold_method"
  ],
  "title": "ComplexStructure",
  "type": "object"
}
