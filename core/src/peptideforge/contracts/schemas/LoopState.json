{
  "$defs": {
    "Provenance": {
      "additionalProperties": false,
      "description": "Traceability metadata attached to every stored result.\n\ngit_sha + data_version + tool_versions make every number auditable.\nMissing fields are allowed only for in-memory synthetic plumbing tests.",
      "properties": {
        "git_sha": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Git Sha"
        },
        "data_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Data Version"
        },
        "tool_versions": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Tool Versions",
          "type": "object"
        },
        "config_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Config Hash"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        }
      },
      "title": "Provenance",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Persisted closed-loop campaign state after each DBTL iteration.\n\nReproducible from seed + config when tools are deterministic.",
  "properties": {
    "campaign_id": {
      "format": "uuid",
      "title": "Campaign Id",
      "type": "string"
    },
    "iteration": {
      "minimum": 0,
      "title": "Iteration",
      "type": "integer"
    },
    "seed": {
      "title": "Seed",
      "type": "integer"
    },
    "config": {
      "additionalProperties": true,
      "title": "Config",
      "type": "object"
    },
    "candidate_ids": {
      "default": [],
      "items": {
        "format": "uuid",
        "type": "string"
      },
      "title": "Candidate Ids",
      "type": "array"
    },
    "labeled_ids": {
      "default": [],
      "items": {
        "format": "uuid",
        "type": "string"
      },
      "title": "Labeled Ids",
      "type": "array"
    },
    "oracle_calls": {
      "default": 0,
      "minimum": 0,
      "title": "Oracle Calls",
      "type": "integer"
    },
    "total_cost": {
      "default": 0.0,
      "minimum": 0.0,
      "title": "Total Cost",
      "type": "number"
    },
    "pareto_front_ids": {
      "default": [],
      "items": {
        "format": "uuid",
        "type": "string"
      },
      "title": "Pareto Front Ids",
      "type": "array"
    },
    "surrogate_version": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Surrogate Version"
    },
    "data_version": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Data Version"
    },
    "status": {
      "default": "running",
      "title": "Status",
      "type": "string"
    },
    "notes": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Notes"
    },
    "provenance": {
      "$ref": "#/$defs/Provenance"
    }
  },
  "required": [
    "campaign_id",
    "iteration",
    "seed"
  ],
  "title": "LoopState",
  "type": "object"
}
